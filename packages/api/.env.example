# Rate limiting — all limits are requests per THROTTLE_TTL window
# TTL in milliseconds (default: 1 minute)
THROTTLE_TTL=60000
# Stremio catalog/manifest endpoints — keyed by configId
THROTTLE_STREMIO_LIMIT=120
# Auth endpoints (login, register) — keyed by IP
THROTTLE_AUTH_LIMIT=10
# All other API endpoints — keyed by user ID
THROTTLE_API_LIMIT=60

TMDB_API_KEY=
PORT=3000
# 24h
TMDB_SHORT_CACHE_TTL=86400000
# 30 days
TMDB_LONG_CACHE_TTL=2592000000
# 5 minutes — used for TMDB custom list items (curated lists, curated groups)
TMDB_LIST_CACHE_TTL=300000
# URL of the Angular config app — used for the GET / redirect and manifest configurationURL
CONFIGURE_URL=http://localhost:4200

DATABASE_URL=mongodb://root:example@localhost:27017/myapp-dev?authSource=admin

JWT_SECRET=<64-char random string>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=